type ShipmentEvent {
    id: ID!
    shipmentId: ID!
    status: ShipmentStatus!
    location: String
    comment: String
    createdAt: String!
}

extend type Mutation {
    addShipmentEvent(
        shipmentId: ID!
        status: ShipmentStatus!
        location: String
        comment: String
    ): ShipmentEvent
}
